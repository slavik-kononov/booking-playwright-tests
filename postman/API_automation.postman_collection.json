              "\r",
              "        pm.expect(pm.response.code).to.eql(405);\r",
              "        pm.expect(jsonData).to.have.property(\"error\");\r",
              "        pm.expect(jsonData.error).to.include(\"daily request limit\");\r",
              "    });\r",
              "\r",
              "    pm.execution.setNextRequest(null);\r",
              "} else {\r",
              "pm.test(\"GET after DELETE: status code is 404\", function () {\r",
              "    pm.response.to.have.status(404);\r",
              "});\r",
              "\r",
              "pm.test(\"GET after DELETE: deleted object is not returned\", function () {\r",
              "    const responseText = pm.response.text().trim();\r",
              "\r",
              "    if (responseText.length > 0) {\r",
              "        const jsonData = pm.response.json();\r",
              "\r",
              "        pm.expect(jsonData).to.be.an(\"object\");\r",
              "\r",
              "        pm.expect(jsonData).to.not.have.property(\"id\");\r",
              "        pm.expect(jsonData).to.not.have.property(\"name\");\r",
              "        pm.expect(jsonData).to.not.have.property(\"data\");\r",
              "    } else {\r",
              "        pm.expect(responseText).to.eql(\"\");\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"GET after DELETE: error message is correct\", function () {\r",
              "    const objectId = pm.collectionVariables.get(\"objectId\");\r",
              "    pm.expect(jsonData.error).to.eql(`Object with id=${objectId} was not found.`);\r",
              "});\r",
              "\r",
              "pm.test(\"GET after DELETE: cleanup collection variable objectId\", function () {\r",
              "    console.log(\"Deleted objectId:\", pm.collectionVariables.get(\"objectId\"));\r",
              "    pm.collectionVariables.unset(\"objectId\");\r",
              "});\r",
              "}"
