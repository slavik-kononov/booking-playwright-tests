              "});\r",
              "\r",
              "pm.test(\"GET created: name matches POST data\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"name\");\r",
              "    pm.expect(jsonData.name).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.name).to.eql(pm.collectionVariables.get(\"expectedName\"));\r",
              "});\r",
              "\r",
              "pm.test(\"GET created: data is object\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"data\");\r",
              "    pm.expect(jsonData.data).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "pm.test(\"GET created: color matches POST data\", function () {\r",
              "    pm.expect(jsonData.data).to.have.property(\"color\");\r",
              "    pm.expect(jsonData.data.color).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.data.color).to.eql(pm.collectionVariables.get(\"expectedColor\"));\r",
              "});\r",
              "\r",
              "pm.test(\"GET created: description matches POST data\", function () {\r",
              "    pm.expect(jsonData.data).to.have.property(\"description\");\r",
              "    pm.expect(jsonData.data.description).to.be.a(\"string\");\r",
              "    pm.expect(jsonData.data.description).to.eql(pm.collectionVariables.get(\"expectedDescription\"));\r",
              "});\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
