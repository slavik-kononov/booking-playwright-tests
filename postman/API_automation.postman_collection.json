    {
      "name": "Delete Object",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "//в случае преувеличения лимита запросов на роут без авторизации\r",
              "function isDailyLimitReached() {\r",
              "    if (pm.response.code !== 405) {\r",
              "        return false;\r",
              "    }\r",
              "\r",
              "    const responseText = pm.response.text();\r",
              "\r",
              "    if (!responseText) {\r",
              "        return false;\r",
              "    }\r",
              "\r",
              "    const jsonData = pm.response.json();\r",
              "\r",
              "    return jsonData.error &&\r",
              "        jsonData.error.includes(\"daily request limit\");\r",
              "}\r",
              "\r",
              "if (isDailyLimitReached()) {\r",
              "    pm.test(\"API limit: daily request limit reached\", function () {\r",
              "        const jsonData = pm.response.json();\r",
              "\r",
              "        pm.expect(pm.response.code).to.eql(405);\r",
              "        pm.expect(jsonData).to.have.property(\"error\");\r",
              "        pm.expect(jsonData.error).to.include(\"daily request limit\");\r",
              "    });\r",
              "\r",
              "    pm.execution.setNextRequest(null);\r",
              "} else {\r",
              "let jsonData;\r",
              "\r",
              "pm.test(\"DELETE: status code is 200\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200]);\r",
              "});\r",
              "\r",
              "pm.test(\"DELETE: response is valid if body exists\", function () {\r",
              "    const responseText = pm.response.text().trim();\r",
              "\r",
              "    if (responseText.length > 0) {\r",
              "        pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/json\");\r",
              "\r",
              "        jsonData = pm.response.json();\r",
              "        pm.expect(jsonData).to.be.an(\"object\");\r",
              "\r",
              "        if (jsonData.message) {\r",
              "            pm.expect(jsonData.message).to.be.a(\"string\");\r",
              "            pm.expect(jsonData.message).to.include(pm.collectionVariables.get(\"objectId\"));\r",
              "        }\r",
              "    } else {\r",
              "        pm.expect(responseText).to.eql(\"\");\r",
              "    }\r",
              "    });\r",
              "\r",
              "    pm.test(\"DELETE: message exists and is string\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"message\");\r",
              "    pm.expect(jsonData.message).to.be.a(\"string\");\r",
              "});\r",
              "\r",
              "pm.test(\"DELETE: message is correct\", function () {\r",
              "    const objectId = pm.collectionVariables.get(\"objectId\");\r",
              "    pm.expect(jsonData.message).to.eql(`Object with id = ${objectId} has been deleted.`);\r",
              "});\r",
              "}"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
