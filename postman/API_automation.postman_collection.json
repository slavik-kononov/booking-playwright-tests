              "pm.test(\"GET created: response body is object\", function () {\r",
              "    pm.expect(jsonData).to.be.an(\"object\");\r",
              "});\r",
              "\r",
              "pm.test(\"GET created: id matches saved objectId\", function () {\r",
              "    pm.expect(jsonData).to.have.property(\"id\");\r",
